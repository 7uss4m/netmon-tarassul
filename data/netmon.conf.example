# JWT / encryption (use a strong secret in production)
JWT_SECRET=change-me-in-production

# Server
PORT=5000

# Dashboard login
ADMIN_USERNAME=admin
# add this using in the ui for more security
#ADMIN_PASSWORD=

# Tarassul API
TARASSUL_BASE_URL=http://syriantelecom.com.sy/Sync/selfPortal.php
TARASSUL_USERNAME=
# add this using in the ui for more security
#TARASSUL_PASSWORD=
TARASSUL_FID=3
TARASSUL_LANG=1

# Fetch schedule (hours 0–23, twice daily)
FETCH_HOUR_1=8
FETCH_HOUR_2=20

# ntfy push notifications (optional)
NTFY_URL=
# add this using in the ui for more security
#NTFY_TOKEN=

# UI theme: dark or light
THEME=dark
